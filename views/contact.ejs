<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>お問い合わせ | Tiny-URL</title>
    <meta name="description" content="Tiny-URLへのお問い合わせページ。サービスに関するご質問やご意見をお気軽にお寄せください。">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">Tiny-URL</a>
            <ul class="navbar-nav">
                <li><a href="/">ホーム</a></li>
                <li><a href="/api/reference">APIリファレンス</a></li>
                <% if (typeof name !== 'undefined' && name) { %>
                    <li><a href="/dashboard">ダッシュボード</a></li>
                    <li><a href="/logout" class="btn-nav-danger">ログアウト</a></li>
                <% } else { %>
                    <li><a href="/buy">プレミアム</a></li>
                    <li><a href="/login" class="btn-nav-primary">ログイン</a></li>
                <% } %>
            </ul>
            <button class="navbar-toggle" id="menu-button" aria-label="メニューを開く" title="メニュー">&#9776;</button>
        </div>
    </nav>
    <div class="mobile-menu hidden" id="mobile-menu">
        <a href="/">ホーム</a>
        <a href="/api/reference">APIリファレンス</a>
        <% if (typeof name !== 'undefined' && name) { %>
            <a href="/dashboard">ダッシュボード</a>
            <a href="/logout" class="btn-nav-danger">ログアウト</a>
        <% } else { %>
            <a href="/buy">プレミアム</a>
            <a href="/login" class="btn-nav-primary">ログイン</a>
        <% } %>
    </div>

    <div class="page-wrap">
        <div class="main-content">
            <div class="container-sm">
                <div class="panel">
                    <div class="panel-heading">
                        <h2>お問い合わせ</h2>
                    </div>
                    <div class="panel-body">
                        <% if (typeof success !== 'undefined' && success) { %>
                            <div class="alert alert-success">
                                <strong>✓ お問い合わせを受け付けました</strong><br>
                                <span class="text-sm">ご連絡ありがとうございます。内容を確認の上、折り返しご連絡いたします。</span>
                            </div>
                        <% } %>

                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger">
                                <strong>✗ エラーが発生しました</strong><br>
                                <span class="text-sm"><%= error %></span>
                            </div>
                        <% } %>

                        <p class="text-muted">サービスに関するご質問、ご意見、不具合報告などがございましたら、以下のフォームよりお気軽にお問い合わせください。</p>

                        <form action="/contact" method="POST">
                            <div class="form-group">
                                <label for="name">お名前 <span class="required">*</span></label>
                                <input type="text" id="name" name="name" class="form-control" placeholder="山田 太郎" required>
                            </div>

                            <div class="form-group">
                                <label for="email">メールアドレス <span class="required">*</span></label>
                                <input type="email" id="email" name="email" class="form-control" placeholder="example@email.com" required>
                            </div>

                            <div class="form-group">
                                <label for="subject">件名 <span class="required">*</span></label>
                                <input type="text" id="subject" name="subject" class="form-control" placeholder="お問い合わせの件名" required>
                            </div>

                            <div class="form-group">
                                <label for="category">お問い合わせ種別</label>
                                <select id="category" name="category" class="form-control">
                                    <option value="general">一般的なお問い合わせ</option>
                                    <option value="bug">不具合報告</option>
                                    <option value="feature">機能要望</option>
                                    <option value="account">アカウントについて</option>
                                    <option value="premium">プレミアムプランについて</option>
                                    <option value="other">その他</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="message">お問い合わせ内容 <span class="required">*</span></label>
                                <textarea id="message" name="message" rows="8" class="form-control"
                                    placeholder="お問い合わせ内容を詳しくご記入ください" required></textarea>
                            </div>

                            <p class="text-muted text-sm">
                                送信いただいた情報は、<a href="/privacy">プライバシーポリシー</a>に基づき適切に管理いたします。
                            </p>

                            <button type="submit" class="btn btn-primary btn-block btn-lg">送信する</button>
                        </form>

                        <hr>
                        <h3 style="font-size:15px;">その他のお問い合わせ方法</h3>
                        <p class="text-muted text-sm">
                            緊急のお問い合わせの場合は、メールでも受け付けております：<br>
                            <a href="mailto:support@orrn.net">support@orrn.net</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="site-footer">
        &copy; <script>document.write(new Date().getFullYear())</script> Tiny-URL. All rights reserved. |
        <a href="/policy">利用規約</a> |
        <a href="/privacy">プライバシーポリシー</a> |
        <a href="/contact">お問い合わせ</a>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const menuButton = document.getElementById('menu-button');
            const mobileMenu = document.getElementById('mobile-menu');
            if (menuButton && mobileMenu) {
                menuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
            }
        });
    </script>
</body>
</html>
