<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ダッシュボード | Tiny-URL</title>
    <meta name="description" content="Tiny-URLのダッシュボード。短縮したURLの一覧、編集、削除、アクセス統計の確認など、すべての機能を一括管理できます。">
    <meta name="robots" content="noindex">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">Tiny-URL</a>
            <ul class="navbar-nav">
                <li><a href="/">ホーム</a></li>
                <li><a href="/api/reference">APIリファレンス</a></li>
                <li><a href="/buy">プレミアム</a></li>
                <li><a href="/logout" class="btn-nav-danger">ログアウト</a></li>
            </ul>
            <button class="navbar-toggle" id="menu-button" aria-label="メニューを開く" title="メニュー">&#9776;</button>
        </div>
    </nav>
    <div class="mobile-menu hidden" id="mobile-menu">
        <a href="/">ホーム</a>
        <a href="/api/reference">APIリファレンス</a>
        <a href="/buy">プレミアム</a>
        <a href="/logout" class="btn-nav-danger">ログアウト</a>
    </div>

    <div class="page-wrap">
        <div class="main-content">
            <div class="container">
                <div style="margin-bottom:20px;">
                    <h1 style="font-size:26px; margin-bottom:4px;">ダッシュボード</h1>
                    <p class="text-muted">ようこそ、<strong><%= name %></strong> さん</p>
                </div>

                <!-- 統計カード -->
                <div class="stats-row">
                    <div class="stat-card">
                        <p class="stat-label">総URL数</p>
                        <p class="stat-value"><%= stats.totalUrls || 0 %></p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">今月のAPI使用</p>
                        <p class="stat-value"><%= apiUsageCount !== undefined ? apiUsageCount : 0 %></p>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">プラン</p>
                        <p class="stat-value" style="font-size:20px; color:<%= premiu ? '#8a6d3b' : '#333' %>">
                            <%= premiu ? 'プレミアム' : 'フリー' %>
                        </p>
                        <% if (!premiu) { %>
                            <p class="stat-sub"><a href="/buy">アップグレード →</a></p>
                        <% } %>
                    </div>
                    <div class="stat-card">
                        <p class="stat-label">APIトークン</p>
                        <p class="stat-value"><%= apiTokens ? apiTokens.length : 0 %></p>
                    </div>
                </div>

                <!-- メインコンテンツ -->
                <div class="layout-main">
                    <!-- URL一覧 -->
                    <div class="col-main">
                        <div class="panel">
                            <div class="panel-heading" style="display:flex; justify-content:space-between; align-items:center;">
                                <h2>短縮URL一覧</h2>
                                <a href="/" class="btn btn-primary btn-sm">+ 新規作成</a>
                            </div>
                            <div class="panel-body" style="padding:0 16px 16px;">

                                <% if (content && content.length > 0) { %>
                                    <form method="POST" action="/dashboard/delete" id="deleteForm">
                                        <div style="overflow-x:auto; margin-top:12px;">
                                            <table class="table table-hover">
                                                <thead>
                                                    <tr>
                                                        <th style="width:32px;">
                                                            <input type="checkbox" id="select-all" title="全て選択">
                                                        </th>
                                                        <th>オリジナルURL</th>
                                                        <th>短縮URL</th>
                                                        <th>作成日</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% for (var i in content) { %>
                                                        <% var obj = content[i]; %>
                                                        <tr>
                                                            <td>
                                                                <input type="checkbox" name="delnum" value="<%= obj.tiny %>"
                                                                    class="row-checkbox">
                                                            </td>
                                                            <td class="url-cell" title="<%= obj.original %>">
                                                                <a href="<%= obj.original %>" target="_blank" rel="noopener noreferrer">
                                                                    <%= obj.original %>
                                                                </a>
                                                            </td>
                                                            <td>
                                                                <div class="d-flex align-items-center gap-4">
                                                                    <a href="/t/<%= obj.tiny %>" target="_blank"
                                                                        style="font-family:monospace; font-size:12px;">
                                                                        /t/<%= obj.tiny %>
                                                                    </a>
                                                                    <button type="button"
                                                                        onclick="copyToClipboard(window.location.origin + '/t/<%= obj.tiny %>')"
                                                                        class="btn btn-default btn-sm" title="コピー"
                                                                        style="padding:2px 6px;">
                                                                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                                                                        </svg>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                            <td style="font-size:12px; color:#777; white-space:nowrap;">
                                                                <%= obj.createdAt ? new Date(obj.createdAt).toLocaleDateString('ja-JP') : '不明' %>
                                                            </td>
                                                        </tr>
                                                    <% } %>
                                                </tbody>
                                            </table>
                                        </div>

                                        <!-- ページネーション -->
                                        <% if (pagination && pagination.totalPages > 1) { %>
                                            <div class="pagination-row">
                                                <span class="pagination-info">
                                                    <%= pagination.totalUrls %>件中
                                                    <%= ((pagination.currentPage - 1) * pagination.limit + 1) %>〜<%= Math.min(pagination.currentPage * pagination.limit, pagination.totalUrls) %>件を表示
                                                </span>
                                                <div class="pagination-nav">
                                                    <a href="?page=<%= pagination.currentPage - 1 %>&limit=<%= pagination.limit %>"
                                                        class="btn btn-sm <%= pagination.currentPage === 1 ? 'btn-default disabled' : 'btn-primary' %>">
                                                        ← 前へ
                                                    </a>
                                                    <span class="text-muted" style="font-size:13px;">
                                                        <%= pagination.currentPage %> / <%= pagination.totalPages %>
                                                    </span>
                                                    <a href="?page=<%= pagination.currentPage + 1 %>&limit=<%= pagination.limit %>"
                                                        class="btn btn-sm <%= pagination.currentPage >= pagination.totalPages ? 'btn-default disabled' : 'btn-primary' %>">
                                                        次へ →
                                                    </a>
                                                </div>
                                                <div class="d-flex align-items-center gap-8">
                                                    <span class="text-muted" style="font-size:12px;">表示件数:</span>
                                                    <select onchange="window.location.href='?page=1&limit='+this.value"
                                                        class="form-control" style="height:28px; width:80px; font-size:12px; padding:2px 6px;">
                                                        <option value="10" <%= pagination.limit===10?'selected':'' %>>10件</option>
                                                        <option value="20" <%= pagination.limit===20?'selected':'' %>>20件</option>
                                                        <option value="50" <%= pagination.limit===50?'selected':'' %>>50件</option>
                                                        <option value="100" <%= pagination.limit===100?'selected':'' %>>100件</option>
                                                    </select>
                                                </div>
                                            </div>
                                        <% } %>

                                        <div class="d-flex gap-8 flex-wrap" style="margin-top:12px;">
                                            <button type="submit" id="deleteSelectedBtn" class="btn btn-danger btn-sm">
                                                選択したURLを削除
                                            </button>
                                            <% if (stats.totalUrls > 1) { %>
                                                <button type="button" id="deleteAllBtn"
                                                    class="btn btn-danger-muted btn-sm"
                                                    title="全ての短縮URL（全ページ）を削除します">
                                                    全て削除（<%= stats.totalUrls %>件）
                                                </button>
                                            <% } %>
                                        </div>
                                    </form>

                                    <!-- 全削除用フォーム -->
                                    <form id="deleteAllForm" method="POST" action="/dashboard/delete-all" class="hidden"></form>

                                <% } else { %>
                                    <div class="text-center" style="padding:40px 0;">
                                        <p class="text-muted" style="font-size:32px; margin-bottom:8px;">🔗</p>
                                        <h3 style="color:#777; font-size:16px; margin-bottom:6px;">短縮URLがありません</h3>
                                        <p class="text-muted text-sm">最初の短縮URLを作成してみましょう</p>
                                        <a href="/" class="btn btn-primary">URL短縮を開始</a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- サイドバー -->
                    <div class="col-side">
                        <!-- APIトークン管理 -->
                        <div class="panel">
                            <div class="panel-heading">
                                <h3>APIトークン</h3>
                            </div>
                            <div class="panel-body">
                                <p class="text-muted text-sm">APIアクセス用のトークンを管理</p>

                                <% if (apiTokens && apiTokens.length > 0) { %>
                                    <% apiTokens.forEach((token) => { %>
                                        <div class="token-item">
                                            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                                                <div>
                                                    <p class="token-name mb-4"><%= token.name %></p>
                                                    <p class="token-meta mb-0">作成: <%= new Date(token.createdAt).toLocaleDateString('ja-JP') %></p>
                                                    <% if (token.lastUsed) { %>
                                                        <p class="token-meta mb-0">最終使用: <%= new Date(token.lastUsed).toLocaleDateString('ja-JP') %></p>
                                                    <% } %>
                                                </div>
                                                <span class="badge <%= token.isActive ? 'badge-success' : 'badge-danger' %>">
                                                    <%= token.isActive ? '有効' : '無効' %>
                                                </span>
                                            </div>
                                            <div class="token-row">
                                                <input type="password" value="<%= token.token %>" readonly
                                                    class="token-field">
                                                <button type="button" onclick="toggleToken(this)"
                                                    class="btn btn-default btn-sm" title="表示/非表示" style="padding:2px 6px;">
                                                    <svg class="eye-open" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                                    <svg class="eye-closed hidden" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
                                                </button>
                                                <button type="button" onclick="copyToClipboard('<%= token.token %>')"
                                                    class="btn btn-primary btn-sm" title="コピー" style="padding:2px 6px;">
                                                    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5h6m-6 0v4m6-4v4m-6 0h6"></path>
                                                    </svg>
                                                </button>
                                                <form method="POST" action="/dashboard/api-token/delete" style="display:inline;">
                                                    <input type="hidden" name="tokenId" value="<%= token._id %>">
                                                    <button type="submit" onclick="return confirm('このトークンを削除しますか？')"
                                                        class="btn btn-danger btn-sm" title="削除" style="padding:2px 6px;">
                                                        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                        </svg>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    <% }) %>
                                <% } else { %>
                                    <p class="text-muted text-sm">トークンがありません</p>
                                <% } %>

                                <form method="POST" action="/dashboard/api-token/create" style="margin-top:10px;">
                                    <div class="form-group">
                                        <input type="text" name="tokenName" placeholder="トークン名 (オプション)"
                                            class="form-control" style="font-size:13px;">
                                    </div>
                                    <button type="submit" class="btn btn-primary btn-block btn-sm">
                                        新しいトークンを生成
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- プラン情報 -->
                        <% if (!premiu) { %>
                            <div class="panel" style="border-color:#337ab7;">
                                <div class="panel-heading" style="background:#d9edf7; border-color:#bce8f1; color:#31708f;">
                                    <h3>プレミアムにアップグレード</h3>
                                </div>
                                <div class="panel-body text-center">
                                    <p class="text-muted text-sm">無制限URL短縮とカスタムURLを利用できます</p>
                                    <a href="/buy" class="btn btn-primary btn-block">プレミアムプラン</a>
                                </div>
                            </div>
                        <% } else { %>
                            <div class="panel" style="border-color:#f0ad4e;">
                                <div class="panel-heading" style="background:#fcf8e3; border-color:#faebcc; color:#8a6d3b;">
                                    <h3>プレミアム会員</h3>
                                </div>
                                <div class="panel-body">
                                    <ul style="list-style:none; padding:0; margin:0; font-size:13px; color:#3c763d;">
                                        <li>✓ 無制限URL短縮</li>
                                        <li>✓ カスタムURL</li>
                                        <li>✓ 高度なAPI制限</li>
                                    </ul>
                                </div>
                            </div>
                        <% } %>

                        <!-- クイックアクション -->
                        <div class="panel">
                            <div class="panel-heading">
                                <h3>クイックアクション</h3>
                            </div>
                            <div class="panel-body" style="padding:10px;">
                                <a href="/" class="btn btn-default btn-block" style="margin-bottom:8px; text-align:left;">
                                    + 新しいURL短縮
                                </a>
                                <a href="/api/reference" class="btn btn-default btn-block" style="text-align:left;">
                                    APIリファレンス
                                </a>
                            </div>
                        </div>

                        <!-- 使用量 -->
                        <div class="panel">
                            <div class="panel-heading">
                                <h3>今月の使用量</h3>
                            </div>
                            <div class="panel-body">
                                <div style="margin-bottom:14px;">
                                    <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:4px;">
                                        <span>URL短縮</span>
                                        <span class="text-muted">
                                            <%= pagination.totalUrls || 0 %> / <%= premiu ? '無制限' : '1,000' %>
                                        </span>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar"
                                            style="width: <%= premiu ? Math.min((pagination.totalUrls / 1000) * 100, 100) : Math.min(((pagination.totalUrls || 0) / 1000) * 100, 100) %>%"></div>
                                    </div>
                                </div>
                                <div>
                                    <div style="display:flex; justify-content:space-between; font-size:12px; margin-bottom:4px;">
                                        <span>APIリクエスト</span>
                                        <span class="text-muted">
                                            <%= apiUsageCount !== undefined ? apiUsageCount : 0 %> / <%= premiu ? '10,000' : '1,000' %>
                                        </span>
                                    </div>
                                    <div class="progress">
                                        <div class="progress-bar progress-bar-success"
                                            style="width: <%= Math.min(((apiUsageCount || 0) / (premiu ? 10000 : 1000)) * 100, 100) %>%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- コピー通知 -->
    <div id="copy-notification" class="toast">コピーしました！</div>

    <footer class="site-footer">
        &copy; <script>document.write(new Date().getFullYear())</script> Tiny-URL. All rights reserved. |
        <a href="/policy">利用規約</a> |
        <a href="/privacy">プライバシーポリシー</a> |
        <a href="/contact">お問い合わせ</a> |
        <a href="/about">運営者情報</a>
    </footer>

    <script>
        const menuButton = document.getElementById('menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        if (menuButton && mobileMenu) {
            menuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
        }

        // 全選択チェックボックス
        const selectAll = document.getElementById('select-all');
        if (selectAll) {
            selectAll.addEventListener('change', () => {
                document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = selectAll.checked);
            });
            document.querySelectorAll('.row-checkbox').forEach(cb => {
                cb.addEventListener('change', () => {
                    const total = document.querySelectorAll('.row-checkbox').length;
                    const checked = document.querySelectorAll('.row-checkbox:checked').length;
                    selectAll.checked = checked === total;
                    selectAll.indeterminate = checked > 0 && checked < total;
                });
            });
        }

        // 削除フォームのバリデーション
        const deleteForm = document.getElementById('deleteForm');
        if (deleteForm) {
            deleteForm.addEventListener('submit', (e) => {
                const checkboxes = document.querySelectorAll('.row-checkbox:checked');
                if (checkboxes.length === 0) {
                    e.preventDefault();
                    alert('削除するURLを選択してください');
                }
            });
        }

        // 全削除ボタン
        const deleteAllBtn = document.getElementById('deleteAllBtn');
        const deleteAllForm = document.getElementById('deleteAllForm');
        if (deleteAllBtn && deleteAllForm) {
            deleteAllBtn.addEventListener('click', () => {
                if (!confirm('⚠️ 警告：この操作は元に戻せません。\nあなたの全ての短縮URLが完全に削除されます。\n本当に続行しますか？')) return;
                if (!confirm('🚨 最終確認\nすべての短縮URLを削除します。よろしいですか？')) return;
                deleteAllForm.submit();
            });
        }

        // コピー機能
        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(() => {
                const notification = document.getElementById('copy-notification');
                notification.style.opacity = '1';
                notification.style.pointerEvents = 'auto';
                setTimeout(() => {
                    notification.style.opacity = '0';
                    notification.style.pointerEvents = 'none';
                }, 2000);
            }).catch(() => {
                alert('コピーに失敗しました');
            });
        }

        // トークン表示/非表示トグル
        function toggleToken(btn) {
            const input = btn.closest('.token-row').querySelector('.token-field');
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            btn.querySelector('.eye-open').classList.toggle('hidden', isPassword);
            btn.querySelector('.eye-closed').classList.toggle('hidden', !isPassword);
        }
    </script>
</body>
</html>
