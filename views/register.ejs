<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Tiny-URLの新規アカウント登録ページ。無料でアカウントを作成し、URL短縮サービスを便利にご利用いただけます。メールアドレスとパスワードで簡単登録。">
    <title>新規登録 | Tiny-URL</title>
    <link rel="icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">Tiny-URL</a>
            <ul class="navbar-nav">
                <li><a href="/">ホーム</a></li>
                <li><a href="/api/reference">APIリファレンス</a></li>
                <li><a href="/buy">プレミアム</a></li>
                <li><a href="/login" class="btn-nav-primary">ログイン</a></li>
            </ul>
            <button class="navbar-toggle" id="menu-button" aria-label="メニューを開く" title="メニュー">&#9776;</button>
        </div>
    </nav>
    <div class="mobile-menu hidden" id="mobile-menu">
        <a href="/">ホーム</a>
        <a href="/api/reference">APIリファレンス</a>
        <a href="/buy">プレミアム</a>
        <a href="/login" class="btn-nav-primary">ログイン</a>
    </div>

    <div class="page-wrap">
        <div class="main-content">
            <div class="container-sm">
                <div class="text-center mb-16">
                    <h1>アカウント作成</h1>
                    <p class="text-muted">無料でアカウントを作成して、すべての機能をご利用ください。</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger">
                        <strong>エラー:</strong> <%= error %>
                    </div>
                <% } %>

                <div class="panel">
                    <div class="panel-heading">
                        <span class="badge badge-primary">新規登録</span>
                    </div>
                    <div class="panel-body">
                        <form action="/register" method="POST" id="register-form">
                            <div class="form-group">
                                <label for="name">ユーザー名</label>
                                <input type="text" name="name" id="name" class="form-control"
                                    placeholder="ユーザー名を入力してください" required>
                            </div>

                            <div class="form-group">
                                <label for="email">メールアドレス</label>
                                <div class="input-with-btn">
                                    <input type="email" name="email" id="email" class="form-control"
                                        placeholder="メールアドレスを入力してください" required>
                                    <button type="button" id="send-pin-button" class="btn btn-default"
                                        style="white-space:nowrap;">PIN送信</button>
                                </div>
                                <div id="pin-send-status" style="min-height:1.2rem; margin-top:4px; font-size:12px;"></div>
                            </div>

                            <div class="form-group">
                                <label for="password">パスワード（8文字以上）</label>
                                <div class="pw-wrap">
                                    <input type="password" name="password" id="password" class="form-control"
                                        placeholder="パスワード（8文字以上）" required>
                                    <button type="button" class="pw-toggle toggle-password" data-target="password" aria-label="パスワードを表示">
                                        <svg class="eye-open" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                        <svg class="eye-closed hidden" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="password_confirmation">パスワード（確認）</label>
                                <div class="pw-wrap">
                                    <input type="password" name="password_confirmation" id="password_confirmation" class="form-control"
                                        placeholder="パスワードを再入力してください" required>
                                    <button type="button" class="pw-toggle toggle-password" data-target="password_confirmation" aria-label="パスワードを表示">
                                        <svg class="eye-open" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                        </svg>
                                        <svg class="eye-closed hidden" width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>
                                        </svg>
                                    </button>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="pinCode">PINコード</label>
                                <input type="text" name="pinCode" id="pinCode" class="form-control"
                                    placeholder="メールで届いたPINコードを入力"
                                    autocomplete="one-time-code" inputmode="numeric" required>
                            </div>

                            <div class="form-group" style="margin-top:16px;">
                                <label style="font-weight:normal; cursor:pointer;">
                                    <input type="checkbox" name="agree_terms" id="agree-terms" checked>
                                    「<a href="/policy" target="_blank">利用規約</a>」を読み、同意しました
                                </label>
                            </div>

                            <button type="submit" id="register-button" disabled
                                class="btn btn-primary btn-block btn-lg">
                                アカウントを作成する
                            </button>

                            <p class="text-center text-muted text-sm mt-12">
                                既にアカウントをお持ちですか？
                                <a href="/login">ログイン</a>
                            </p>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="site-footer">
        &copy; <script>document.write(new Date().getFullYear())</script> Tiny-URL. All rights reserved. |
        <a href="/policy">利用規約</a> |
        <a href="/privacy">プライバシーポリシー</a> |
        <a href="/contact">お問い合わせ</a> |
        <a href="/about">運営者情報</a>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const menuButton = document.getElementById('menu-button');
            const mobileMenu = document.getElementById('mobile-menu');
            if (menuButton && mobileMenu) {
                menuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
            }

            // パスワード表示トグル
            document.querySelectorAll('.toggle-password').forEach(btn => {
                btn.addEventListener('click', () => {
                    const input = document.getElementById(btn.dataset.target);
                    const isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    btn.querySelector('.eye-open').classList.toggle('hidden', isPassword);
                    btn.querySelector('.eye-closed').classList.toggle('hidden', !isPassword);
                });
            });

            const agreeTermsCheckbox = document.getElementById('agree-terms');
            const registerButton = document.getElementById('register-button');
            const pinInput = document.getElementById('pinCode');
            const sendPinButton = document.getElementById('send-pin-button');
            const pinStatus = document.getElementById('pin-send-status');

            function updateButtonState() {
                const hasPin = pinInput && pinInput.value.trim().length > 0;
                registerButton.disabled = !(agreeTermsCheckbox.checked && hasPin);
            }

            if (agreeTermsCheckbox) agreeTermsCheckbox.addEventListener('change', updateButtonState);
            if (pinInput) pinInput.addEventListener('input', updateButtonState);
            updateButtonState();

            // PIN送信ボタン
            if (sendPinButton) {
                let cooldown = 0;
                let timer = null;

                function startCooldown(seconds) {
                    cooldown = seconds;
                    sendPinButton.disabled = true;
                    timer = setInterval(() => {
                        cooldown--;
                        if (cooldown <= 0) {
                            clearInterval(timer);
                            sendPinButton.disabled = false;
                            sendPinButton.textContent = 'PIN送信';
                        } else {
                            sendPinButton.textContent = `再送信 (${cooldown}s)`;
                        }
                    }, 1000);
                }

                sendPinButton.addEventListener('click', async () => {
                    const emailField = document.getElementById('email');
                    if (!emailField || !emailField.value) {
                        pinStatus.style.color = '#a94442';
                        pinStatus.textContent = 'メールアドレスを入力してください';
                        return;
                    }

                    sendPinButton.disabled = true;
                    sendPinButton.textContent = '送信中...';
                    pinStatus.style.color = '#777';
                    pinStatus.textContent = '送信中...';

                    try {
                        const res = await fetch('/register/send-pin', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email: emailField.value })
                        });
                        const data = await res.json();
                        if (res.ok && data.ok) {
                            pinStatus.style.color = '#3c763d';
                            pinStatus.textContent = 'PINを送信しました。メールをご確認ください。' + (data.expiresAt ? '（有効期限: ' + data.expiresAt + '）' : '');
                            startCooldown(60);
                        } else {
                            pinStatus.style.color = '#a94442';
                            pinStatus.textContent = (data && data.error) ? data.error : 'PIN送信に失敗しました';
                            sendPinButton.disabled = false;
                            sendPinButton.textContent = 'PIN送信';
                        }
                    } catch (err) {
                        console.error('send pin error', err);
                        pinStatus.style.color = '#a94442';
                        pinStatus.textContent = '送信時にエラーが発生しました';
                        sendPinButton.disabled = false;
                        sendPinButton.textContent = 'PIN送信';
                    }
                });
            }
        });
    </script>
</body>
</html>
