<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>プレミアムプラン | Tiny-URL</title>
    <meta name="description" content="Tiny-URLプレミアムプランの購入ページ。カスタムURL、詳細なアクセス解析、QRコード生成、優先サポートなど、充実した機能を月額500円からご利用いただけます。">
    <meta name="keywords" content="短縮,URL,URL短縮,短縮URL">
    <link rel="icon" href="/images/favicon.ico">
    <link rel="preconnect" href="https://www.paypal.com">
    <link rel="stylesheet" href="/css/main.css">
    <script src="https://www.paypal.com/sdk/js?client-id=sb&enable-funding=venmo&currency=JPY"></script>
    <style>
        #paypal-button-monthly, #paypal-button-yearly { min-height: 55px; margin-top: 12px; }
    </style>
</head>
<body>
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">Tiny-URL</a>
            <ul class="navbar-nav">
                <li><a href="/">ホーム</a></li>
                <li><a href="/api/reference">APIリファレンス</a></li>
                <% if (name) { %>
                    <li><a href="/dashboard">ダッシュボード</a></li>
                    <li><a href="/logout" class="btn-nav-danger">ログアウト</a></li>
                <% } else { %>
                    <li><a href="/login" class="btn-nav-primary">ログイン</a></li>
                <% } %>
            </ul>
            <button class="navbar-toggle" id="menu-button" aria-label="メニューを開く" title="メニュー">&#9776;</button>
        </div>
    </nav>
    <div class="mobile-menu hidden" id="mobile-menu">
        <a href="/">ホーム</a>
        <a href="/api/reference">APIリファレンス</a>
        <% if (name) { %>
            <a href="/dashboard">ダッシュボード</a>
            <a href="/logout" class="btn-nav-danger">ログアウト</a>
        <% } else { %>
            <a href="/login" class="btn-nav-primary">ログイン</a>
        <% } %>
    </div>

    <div class="page-wrap">
        <div class="main-content">
            <div class="container">
                <div class="text-center mb-16">
                    <h1 style="font-size:28px;">プレミアムプラン</h1>
                    <p class="text-muted">より多くの機能と柔軟性をお求めの方へ</p>
                    <% if (name) { %>
                        <p class="text-muted text-sm">
                            <strong><%= name %></strong>さん、こんにちは！
                            現在：<strong><%= premiu ? 'プレミアムプラン' : 'フリープラン' %></strong>をご利用中
                        </p>
                    <% } %>
                </div>

                <% if (name) { %>
                    <!-- プラン選択カード -->
                    <div class="plan-row">
                        <!-- 月額プラン -->
                        <div class="plan-card">
                            <div class="text-center" style="margin-bottom:16px;">
                                <h2 style="font-size:20px;">月額プラン</h2>
                                <div>
                                    <span class="plan-price">¥20</span>
                                    <span class="plan-period">/月</span>
                                </div>
                                <p class="text-muted text-sm mb-0">月ごとの柔軟な契約</p>
                            </div>
                            <ul class="feature-list">
                                <li>無制限のURL短縮</li>
                                <li>カスタムURL設定</li>
                                <li>詳細なアクセス統計</li>
                                <li>優先サポート</li>
                            </ul>
                            <div id="paypal-button-monthly"></div>
                        </div>

                        <!-- 年額プラン（人気） -->
                        <div class="plan-card plan-featured">
                            <span class="plan-popular-badge">人気</span>
                            <div class="text-center" style="margin-bottom:16px;">
                                <h2 style="font-size:20px;">年額プラン</h2>
                                <div>
                                    <span class="plan-price">¥200</span>
                                    <span class="plan-period">/年</span>
                                </div>
                                <p class="text-success text-sm mb-4">月額換算 ¥16.7/月 &mdash; 2ヶ月分お得！</p>
                                <p class="text-muted text-sm mb-0">長期利用でさらにお得</p>
                            </div>
                            <ul class="feature-list">
                                <li>無制限のURL短縮</li>
                                <li>カスタムURL設定</li>
                                <li>詳細なアクセス統計</li>
                                <li>優先サポート</li>
                                <li style="color:#337ab7; font-weight:bold;">17%割引（年間¥40お得）</li>
                            </ul>
                            <div id="paypal-button-yearly"></div>
                        </div>
                    </div>

                    <!-- 機能比較表 -->
                    <div class="panel">
                        <div class="panel-heading">
                            <h2>プラン比較</h2>
                        </div>
                        <div class="panel-body" style="padding:0; overflow-x:auto;">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th>機能</th>
                                        <th class="text-center">無料プラン</th>
                                        <th class="text-center text-primary">プレミアムプラン</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>URL短縮数</td>
                                        <td class="text-center text-muted">制限あり</td>
                                        <td class="text-center text-success">無制限</td>
                                    </tr>
                                    <tr>
                                        <td>カスタムURL</td>
                                        <td class="text-center text-danger">✗</td>
                                        <td class="text-center text-success">✓</td>
                                    </tr>
                                    <tr>
                                        <td>アクセス統計</td>
                                        <td class="text-center text-muted">基本のみ</td>
                                        <td class="text-center text-success">詳細</td>
                                    </tr>
                                    <tr>
                                        <td>URL有効期限</td>
                                        <td class="text-center text-muted">30日</td>
                                        <td class="text-center text-success">無期限</td>
                                    </tr>
                                    <tr>
                                        <td>サポート</td>
                                        <td class="text-center text-muted">標準</td>
                                        <td class="text-center text-success">優先</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- 注意事項 -->
                    <div class="alert alert-info">
                        <strong>ご利用にあたって</strong>
                        <ul style="margin:8px 0 0; padding-left:20px; font-size:13px;">
                            <li>お支払いはPayPalを通じて安全に処理されます</li>
                            <li>プレミアム機能は決済完了後すぐにご利用いただけます</li>
                            <li>解約はいつでも可能です（次回更新日まで利用可能）</li>
                        </ul>
                    </div>

                <% } else { %>
                    <!-- 未ログイン時の表示 -->
                    <div class="container-sm">
                        <div class="panel text-center">
                            <div class="panel-body" style="padding:40px 24px;">
                                <h2>ログインが必要です</h2>
                                <p class="text-muted">プレミアムプランをご購入いただくには、まずログインしてください。</p>
                                <a href="/login" class="btn btn-primary btn-lg">ログイン</a>
                                <p class="text-muted text-sm mt-12">
                                    アカウントをお持ちでない方は
                                    <a href="/register">こちら</a>から登録
                                </p>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <footer class="site-footer">
        &copy; <script>document.write(new Date().getFullYear())</script> Tiny-URL. All rights reserved. |
        <a href="/policy">利用規約</a> |
        <a href="/privacy">プライバシーポリシー</a> |
        <a href="/contact">お問い合わせ</a> |
        <a href="/about">運営者情報</a>
    </footer>

    <script>
        const menuButton = document.getElementById('menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        if (menuButton && mobileMenu) {
            menuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
        }
    </script>

    <% if (name) { %>
        <script>
            paypal.Buttons({
                style: { layout: 'vertical', color: 'blue', shape: 'rect', label: 'paypal', height: 45 },
                createOrder: function (data, actions) {
                    return actions.order.create({
                        purchase_units: [{ amount: { value: '20', currency_code: 'JPY' }, description: 'Tiny-URL プレミアムプラン（月額）' }]
                    });
                },
                onApprove: function (data, actions) {
                    return actions.order.capture().then(function (details) {
                        alert('お支払いが完了しました！プレミアム機能をお楽しみください。');
                        window.location.href = '/dashboard';
                    });
                },
                onError: function (err) {
                    console.error('PayPalエラー:', err);
                    alert('お支払い処理中にエラーが発生しました。もう一度お試しください。');
                }
            }).render('#paypal-button-monthly');

            paypal.Buttons({
                style: { layout: 'vertical', color: 'blue', shape: 'rect', label: 'paypal', height: 45 },
                createOrder: function (data, actions) {
                    return actions.order.create({
                        purchase_units: [{ amount: { value: '200', currency_code: 'JPY' }, description: 'Tiny-URL プレミアムプラン（年額）' }]
                    });
                },
                onApprove: function (data, actions) {
                    return actions.order.capture().then(function (details) {
                        alert('お支払いが完了しました！プレミアム機能をお楽しみください。');
                        window.location.href = '/dashboard';
                    });
                },
                onError: function (err) {
                    console.error('PayPalエラー:', err);
                    alert('お支払い処理中にエラーが発生しました。もう一度お試しください。');
                }
            }).render('#paypal-button-yearly');
        </script>
    <% } %>
</body>
</html>
