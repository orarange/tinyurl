<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="無料で使える高速URL短縮サービスTiny-URL。長いリンクを短くして簡単に共有。プレミアムプランではカスタムURL、アクセス解析、QRコード生成などの機能をご利用いただけます。">
    <title>Tiny-URL | 最速のURL短縮サービス</title>
    <link rel="icon" href="/images/favicon.ico">
    <link rel="stylesheet" href="/css/main.css">
</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-GREHT23WLE"></script>
<script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-GREHT23WLE');
</script>
<body>
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">Tiny-URL</a>
            <ul class="navbar-nav">
                <li><a href="/">ホーム</a></li>
                <li><a href="/api/reference">APIリファレンス</a></li>
                <% if (name) { %>
                    <li><a href="/dashboard">ダッシュボード</a></li>
                    <li><a href="/logout" class="btn-nav-danger">ログアウト</a></li>
                <% } else { %>
                    <li><a href="/buy">プレミアム</a></li>
                    <li><a href="/login" class="btn-nav-primary">ログイン</a></li>
                <% } %>
            </ul>
            <button class="navbar-toggle" id="menu-button" aria-label="メニューを開く" title="メニュー">&#9776;</button>
        </div>
    </nav>
    <div class="mobile-menu hidden" id="mobile-menu">
        <a href="/">ホーム</a>
        <a href="/api/reference">APIリファレンス</a>
        <% if (name) { %>
            <a href="/dashboard">ダッシュボード</a>
            <a href="/logout" class="btn-nav-danger">ログアウト</a>
        <% } else { %>
            <a href="/buy">プレミアム</a>
            <a href="/login" class="btn-nav-primary">ログイン</a>
        <% } %>
    </div>

    <div class="page-wrap">
        <div class="main-content">
            <div class="container-sm">
                <section class="hero">
                    <h1>短く、速く、強力に。</h1>
                    <p class="lead">
                        複雑なURLを瞬時に短縮し、クリックを追跡。<br>
                        あなたのリンク管理を次のレベルへ。
                    </p>

                    <% if (url === 'error' || tiny === 'error') { %>
                        <div class="alert alert-danger">
                            <strong>エラー:</strong> URLの短縮に失敗しました
                        </div>
                    <% } else if (tiny && tiny.startsWith('http')) { %>
                        <div class="alert alert-success">
                            <strong>✓ URL短縮が完了しました</strong>
                        </div>
                    <% } else if (tiny === 'Already registered') { %>
                        <div class="alert alert-warning">
                            <strong>そのカスタムURLはすでに使用されています。</strong>別のパスを指定してください。
                        </div>
                    <% } else if (tiny && tiny !== '') { %>
                        <div class="alert alert-danger">
                            <strong><%= tiny %></strong>
                        </div>
                    <% } %>

                    <div class="panel">
                        <div class="panel-body">
                            <% if (name) { %>
                                <p class="text-muted text-sm" style="margin-bottom:8px;">
                                    こんにちは、<strong><%= name %></strong>さん
                                </p>
                                <span class="user-badge <%= premiu ? 'user-badge-premium' : 'user-badge-free' %>">
                                    <%= premiu ? 'プレミアムプラン' : 'フリープラン' %>をご利用中
                                </span>
                            <% } else { %>
                                <span class="user-badge user-badge-guest">ゲストユーザー</span>
                            <% } %>

                            <form action="/tiny_url" method="POST" id="url-input-card" style="margin-top:14px;">
                                <div class="form-group">
                                    <input type="url" name="original" id="long-url" class="form-control form-lg"
                                        placeholder="短縮したいURLを入力してください (例: https://very-long-link.com/)"
                                        value="<%= url || '' %>" required>
                                </div>

                                <% if (premiu) { %>
                                    <div class="form-group">
                                        <div class="input-group">
                                            <span class="input-group-addon" style="font-family:monospace; font-size:12px;">https://<%= domain %>/t/</span>
                                            <input type="text" name="custom" id="custom-path" class="form-control"
                                                placeholder="カスタムパス (オプション)" value="">
                                        </div>
                                    </div>
                                <% } %>

                                <div class="form-group">
                                    <label style="font-weight:normal; cursor:pointer; font-size:13px;">
                                        <input type="checkbox" name="agree_terms" id="agree-terms" checked>
                                        「<a href="https://orrn.net/policy" target="_blank">利用規約</a>」を読み、同意しました
                                    </label>
                                </div>

                                <button type="submit" id="shorten-button" class="btn btn-primary btn-block btn-lg">
                                    短縮する
                                </button>
                            </form>
                        </div>
                    </div>

                    <% if (tiny && tiny.startsWith('http')) { %>
                        <div class="panel" style="border-color:#5cb85c;">
                            <div class="panel-heading" style="background:#dff0d8; border-color:#5cb85c; color:#3c763d;">
                                <h3 style="margin:0; font-size:14px;">短縮完了！</h3>
                            </div>
                            <div class="panel-body">
                                <div class="copy-group">
                                    <input type="text" id="short-url-output" readonly value="<%= tiny %>"
                                        class="form-control" style="font-family:monospace;">
                                    <button id="copy-button" class="btn btn-success" style="white-space:nowrap;">
                                        <span id="copy-text">コピー</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </section>
            </div>
        </div>
    </div>

    <footer class="site-footer">
        &copy; <script>document.write(new Date().getFullYear())</script> Tiny-URL. All rights reserved. |
        <a href="/policy">利用規約</a> |
        <a href="/privacy">プライバシーポリシー</a> |
        <a href="/contact">お問い合わせ</a> |
        <a href="/about">運営者情報</a>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const menuButton = document.getElementById('menu-button');
            const mobileMenu = document.getElementById('mobile-menu');
            if (menuButton && mobileMenu) {
                menuButton.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));
            }

            const shortUrlOutput = document.getElementById('short-url-output');
            const copyButton = document.getElementById('copy-button');
            const copyText = document.getElementById('copy-text');
            const agreeTermsCheckbox = document.getElementById('agree-terms');
            const shortenButton = document.getElementById('shorten-button');

            if (shortUrlOutput && copyButton) {
                copyButton.addEventListener('click', () => {
                    navigator.clipboard.writeText(shortUrlOutput.value).then(() => {
                        copyText.textContent = 'コピーしました！';
                        copyButton.classList.remove('btn-success');
                        copyButton.classList.add('btn-primary');
                        setTimeout(() => {
                            copyText.textContent = 'コピー';
                            copyButton.classList.remove('btn-primary');
                            copyButton.classList.add('btn-success');
                        }, 2500);
                    }).catch(() => {
                        copyText.textContent = 'コピー失敗';
                    });
                });
            }

            if (agreeTermsCheckbox && shortenButton) {
                agreeTermsCheckbox.addEventListener('change', () => {
                    shortenButton.disabled = !agreeTermsCheckbox.checked;
                });
                shortenButton.disabled = !agreeTermsCheckbox.checked;
            }

            // Google Ads の遅延読み込み
            let adsLoaded = false;
            function loadGoogleAds() {
                if (adsLoaded) return;
                adsLoaded = true;
                const script = document.createElement('script');
                script.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4006009538073290';
                script.async = true;
                script.crossOrigin = 'anonymous';
                document.head.appendChild(script);
            }
            window.addEventListener('scroll', loadGoogleAds, { once: true, passive: true });
            document.addEventListener('click', loadGoogleAds, { once: true });
            document.addEventListener('touchstart', loadGoogleAds, { once: true, passive: true });
            setTimeout(loadGoogleAds, 3000);
        });
    </script>
</body>
</html>
